{
  "name": "@seopen/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The seopen command-line interface.",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "seopen": "./dist/bin.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --build",
    "test": "node --import tsx --conditions=source --test test/*.test.ts"
  },
  "dependencies": {
    "@seopen/fetch": "workspace:*",
    "@seopen/parse": "workspace:*",
    "@seopen/scoring": "workspace:*",
    "@seopen/types": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
