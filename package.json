{
  "name": "seopen",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source self-hostable platform for SEO and Generative Engine Optimization.",
  "author": "ahernandez-developer",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --build",
    "build": "tsc --build",
    "clean": "tsc --build --clean && rimraf \"**/dist\" \"**/*.tsbuildinfo\"",
    "test": "pnpm --recursive --stream --filter \"./packages/*\" test"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^20.17.6",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0"
  }
}
